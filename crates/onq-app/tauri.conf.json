  "productName": "onQ",
  "version": "1.10.0",
  "identifier": "com.visorcraft.onq",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      { "title": "onQ", "width": 1200, "height": 800, "minWidth": 800, "minHeight": 600 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
