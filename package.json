{
  "name": "onQ",
  "version": "1.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --ext .ts,.svelte",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test tests/a11y/",
    "bench": "cargo bench -p onq-core",
    "tauri": "tauri",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "dev:app": "tauri dev --config crates/onq-app/tauri.conf.json",
    "build:app": "tauri build --config crates/onq-app/tauri.conf.json"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/svelte-vite": "^10.5.2",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@tauri-apps/cli": "^2.11.4",
    "@tsconfig/svelte": "^5.0.8",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-storybook": "^10.5.2",
    "eslint-plugin-svelte": "^2.44.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.45",
    "storybook": "^10.5.2",
    "svelte": "^5.56.6",
    "svelte-check": "^4.7.3",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.7.0",
    "typescript": "~5.9",
    "vite": "^8.1.5",
    "vitepress": "^2.0.0-alpha.18",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "bits-ui": "^1.0.0"
  }
}
